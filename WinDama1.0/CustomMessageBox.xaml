<Window x:Class="WinDama.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinDama"
        mc:Ignorable="d"
        Title="Custom Message Box" Height="200" Width="300">
    <Grid>
        <TextBlock Name="MessageTextBlock" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Margin="10"/>
        <Button Name="OkButton" Content="OK" Width="75" Height="30" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10" Click="OkButton_Click"/>
    </Grid>
</Window>